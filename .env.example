# REQUIRED Environment Variables (Hackathon Guidelines)
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face (Optional - for deployment)
HF_TOKEN=your_huggingface_token_here

# Environment Configuration
ENVIRONMENT=production
LOG_LEVEL=INFO

# Database Configuration (SQLite in-memory by default)
DB_PATH=:memory:

# Cost Calculation Settings (AWS RDS Pricing)
COST_PER_VCPU_HOUR=0.10
COST_PER_GB_STORAGE_MONTH=0.10
COST_PER_MILLION_IOPS=0.20
